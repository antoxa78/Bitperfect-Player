<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:id="@+id/img_track_icon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_audio"
        android:contentDescription="Track Icon" />

    <TextView
        android:id="@+id/text_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Song Title"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_artist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Artist Name"
        android:textColor="#AAAAAA"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/text_album"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Album Name"
        android:textColor="#888888"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/text_playlist_pos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="0 / 0"
        android:textColor="#888888"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/text_bitrate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="--- kbps | -- kHz"
        android:textColor="#00E676"
        android:textSize="14sp" />

    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/text_current_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#AAAAAA" />

        <View
            android:layout_width="540dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/text_total_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#AAAAAA" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:padding="6dp">

        <ImageButton
            android:id="@+id/btn_shuffle"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_shuffle"
            android:contentDescription="Shuffle"
            android:focusable="true"
            android:padding="20dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF"
            android:alpha="0.5" />

        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_skip_prev"
            android:contentDescription="Previous"
            android:focusable="true"
            android:padding="18dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginHorizontal="14dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_play"
            android:contentDescription="Play/Pause"
            android:focusable="true"
            android:padding="22dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_skip_next"
            android:contentDescription="Next"
            android:focusable="true"
            android:padding="18dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_repeat"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_repeat"
            android:contentDescription="Repeat"
            android:focusable="true"
            android:padding="20dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF"
            android:alpha="0.5" />

        <ImageButton
            android:id="@+id/btn_playlist"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_queue_music"
            android:contentDescription="Playlist"
            android:focusable="true"
            android:padding="18dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
